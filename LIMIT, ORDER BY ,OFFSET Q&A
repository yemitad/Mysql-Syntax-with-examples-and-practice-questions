--1. Find the second highest sales value in the dataset.
Select customer_name, order_id, sub_category,quantity,sales, category ,profit
from sales_data
order by sales desc
limit 1 offset 1

--( limit x offset y) - x - the number of rows to return , y - the number of rows to skip 

--2. Show the third most profitable order.
Select customer_name, order_id, sub_category,quantity,sales, category ,profit
from sales_data
order by profit desc
limit 1 offset 2

--3. Retrieve orders ranked from 6th to 10th based on sales amount
Select customer_name, order_id, sub_category,quantity,sales, category ,profit
from Sales_data
order by sales desc
limit 5 offset 5;

--4. Display the next 5 records after the top 5 highest sales orders
Select customer_name, order_id, sub_category,quantity,sales, category ,profit
from Sales_data
order by sales desc
limit 5 offset 5;

--5. Skip the first 10 highest profit orders and show the following 10.
Select customer_name, order_id,sub_category, quantity, sales, category, profit
from Sales_data
Order by profit desc
limit 10 offset 10;

6. Show the top 5 highest sales orders only from the Furniture category.
Select customer_name, order_id,sub_category, quantity, sales, category, profit
from Sales_data
order by sales desc
limit 5; 

7. Retrieve the 3 least profitable Technology orders.
Select customer_name, order_id,sub_category, quantity, sales, category, profit
from Sales_data
Where category ='Technology'
order by profit asc
limit 3;


8. Display the first 10 orders from the West region after sorting by sales.
Select customer_name, order_id,sub_category, quantity, sales, category, profit
from Sales_data
Where region ='West'
order by sales
limit 10;

9. Show the most discounted 5 orders from Texas.
Select customer_name, discount, sales, category, profit
from sales_data
Where state ='Texas'
order by discount desc
limit 5;


