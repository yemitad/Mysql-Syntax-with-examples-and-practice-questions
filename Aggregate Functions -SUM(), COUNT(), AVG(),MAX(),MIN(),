1. Find regions where total sales is greater than 50,000.
SELECT region, SUM(sales) as Total_sales
FROM  sales_data 
GROUP BY region 
HAVING SUM(sales) > 50000;

2. Find states where total profit is negative.
SELECT state, SUM(profit) as Total_profit
FROM  'Sales_data.csv'
GROUP BY state
HAVING sum(profit) < 0;

3. Find categories where average profit is greater than 500.
SELECT category, AVG(profit) AS Average_profit
FROM 'Sales_data.csv'
GROUP BY category
HAVING AVG(profit) > 500;

4. Find cities having more than 100 orders.
SELECT city, COUNT(*) as number_of_orders
FROM  'Sales_data.csv'
GROUP BY city 
HAVING COUNT(*) > 100;


5. Find customers whose total sales is more than 20,000.
SELECT customer_name, SUM(sales) as Total_sales
FROM 'Sales_data.csv'
GROUP BY customer_name 
HAVING SUM(sales) >20000;

6. Find sub_categories where total quantity sold is greater than 300.

SELECT sub_category, SUM(quantity) as Total_quantity
From 'Sales_data.csv'
GROUP BY sub_category
HAVING SUM(quantity) > 300;

7. Find regions where average discount is greater than 0.3.
SELECT region, AVG(discount) as Average_discount
FROM 'Sales_data.csv'
GROUP BY region 
HAVING AVG(discount) > 0.3;


8. Find segments where total profit is greater than total sales.
SELECT segment, SUM(profit) as Total_profit, SUM(sales) as Total_sales
FROM 'Sales_data.csv'
GROUP BY segment
HAVING SUM(profit) > SUM(sales);

9. Find category and region combinations where total sales is more than
30,000.
SELECT category, region, SUM(sales) as Total_sales
FROM 'Sales_data.csv'
GROUP BY category,region
HAVING SUM(sales) >30000;

10.Find ship modes where total profit is less than 0.
SELECT ship_mode, SUM(profit) as Total_profit 
FROM 'Sales_data.csv'
GROUP BY ship_mode
HAVING SUM(profit) < 0; 

11.Find states where total discount given is greater than 200.
SELECT state, SUM(discount) as Total_discount
FROM 'Sales_data.csv'
GROUP BY state
HAVING SUM(discount) > 200; 

12.Find customers who placed more than 10 orders.
SELECT customer_name, COUNT(*) as Regular_customers
FROM 'Sales_data.csv'
GROUP BY customer_name
HAVING COUNT(*) > 10; 

13.Find sub_categories where average sales is less than 200.
SELECT sub_category, AVG(sales) as Average_sales
FROM 'Sales_data.csv'
GROUP BY sub_category 
HAVING AVG(sales) < 200; 

14.Find regions where total quantity sold is between 500 and 1000.
SELECT region, SUM(quantity) as Total_quantity
FROM 'Sales_data.csv'
GROUP BY region 
HAVING SUM(quantity) between 500 and 1000; 

15.Find cities where total profit is greater than 10,000.
SELECT city, SUM(profit) as Total_profit
FROM 'Sales_data.csv'
GROUP BY city 
HAVING SUM(profit) > 10000;

16.Which region generates the highest total profit?

SELECT region, sum(profit) as Total_profit
FROM 'Sales_data.csv'
GROUP BY region
ORDER BY Total_profit desc
limit 1; 

17.Which category contributes the most to total sales?

SELECT category, SUM(sales) as Total_sales
FROM 'Sales_data.csv'
GROUP BY category
ORDER BY Total_sales desc 
limit 1; 

18.Which sub_category has the lowest average profit?

SELECT sub_category, AVG(profit) as average_profit
FROM 'Sales_data.csv'
GROUP BY sub_category
ORDER BY average_profit asc
limit 1; 

